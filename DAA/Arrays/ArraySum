#include <iostream>
using namespace std;
int arraySum(int* array, int n){
    int sum = 0;
    for(int i = 0; i < n; i++){
        sum+= array[i];
    }
    return sum;
}
int main(void){
    int n;
    cout<<"Enter number of elements: ";
    cin >> n;
    
    int arr[n];
    for(int i = 0 ; i < n; i++){
        cout<<"Enter element " << i + 1 << ": ";
        cin >> arr[i];
        
    }
        
        cout << "Sum is " << arraySum(arr,n);
}